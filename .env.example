PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lokky
# Pour Docker: mongodb://mongo:27017/lokky
# Pour MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/lokky

# Redis (optionnel - pour le cache des rankings)
REDIS_URL=redis://localhost:6379
# Pour Docker: redis://redis:6379
# Pour Redis Cloud: redis://username:password@host:port

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Apple Sign In (pour plus tard)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

